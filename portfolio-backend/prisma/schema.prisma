generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model achievement {
  id           String    @id
  title        String
  description  String?
  date         DateTime?
  imageId      String?
  displayOrder Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  media        media?    @relation(fields: [imageId], references: [id], map: "Achievement_imageId_fkey")

  @@index([imageId], map: "Achievement_imageId_fkey")
}

model admin {
  id        String   @id
  username  String   @unique(map: "Admin_username_key")
  email     String   @unique(map: "Admin_email_key")
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model certification {
  id                 String    @id
  title              String
  issuer             String
  credentialId       String?
  credentialUrl      String?
  verificationUrl    String?
  issueDate          DateTime?
  certificateImageId String?
  displayOrder       Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime
  media              media?    @relation(fields: [certificateImageId], references: [id], map: "Certification_certificateImageId_fkey")

  @@index([certificateImageId], map: "Certification_certificateImageId_idx")
}

model contactmessage {
  id        String   @id
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.LongText
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead], map: "ContactMessage_isRead_idx")
}

model education {
  id           String    @id
  institution  String
  degree       String
  field        String?
  location     String?
  cgpa         String?
  description  String?   @db.Text
  startDate    DateTime?
  endDate      DateTime?
  displayOrder Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
}

model internship {
  id             String                    @id
  company        String
  position       String
  employmentType internship_employmentType
  location       String?
  description    String?                   @db.LongText
  companyWebsite String?
  logoId         String?
  startDate      DateTime?
  endDate        DateTime?
  displayOrder   Int                       @default(0)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime
  media          media?                    @relation(fields: [logoId], references: [id], map: "Internship_logoId_fkey")

  @@index([logoId], map: "Internship_logoId_idx")
}

model media {
  id                                          String          @id
  fileName                                    String
  fileUrl                                     String
  mimeType                                    String
  fileSize                                    Int
  type                                        media_type
  createdAt                                   DateTime        @default(now())
  updatedAt                                   DateTime
  achievement                                 achievement[]
  certification                               certification[]
  internship                                  internship[]
  portfolio_portfolio_profileImageIdTomedia   portfolio[]     @relation("portfolio_profileImageIdTomedia")
  portfolio_portfolio_resumeIdTomedia         portfolio[]     @relation("portfolio_resumeIdTomedia")
  portfolio_portfolio_workspaceImageIdTomedia portfolio[]     @relation("portfolio_workspaceImageIdTomedia")
  project                                     project[]
  projectimage                                projectimage[]
}

model portfolio {
  id                                      Int      @id @default(1)
  heroTitle                               String?
  heroSubtitle                            String?
  heroDescription                         String?  @db.Text
  aboutTitle                              String?
  aboutDescription                        String?  @db.LongText
  resumeId                                String?
  github                                  String?
  linkedin                                String?
  x                                       String?
  instagram                               String?
  email                                   String?
  phone                                   String?
  address                                 String?
  footerText                              String?  @db.Text
  metaTitle                               String?
  metaDescription                         String?  @db.Text
  keywords                                String?
  profileImageId                          String?
  workspaceImageId                        String?
  createdAt                               DateTime @default(now())
  updatedAt                               DateTime
  media_portfolio_profileImageIdTomedia   media?   @relation("portfolio_profileImageIdTomedia", fields: [profileImageId], references: [id], map: "Portfolio_profileImageId_fkey")
  media_portfolio_resumeIdTomedia         media?   @relation("portfolio_resumeIdTomedia", fields: [resumeId], references: [id], map: "Portfolio_resumeId_fkey")
  media_portfolio_workspaceImageIdTomedia media?   @relation("portfolio_workspaceImageIdTomedia", fields: [workspaceImageId], references: [id], map: "Portfolio_workspaceImageId_fkey")

  @@index([profileImageId], map: "Portfolio_profileImageId_idx")
  @@index([resumeId], map: "Portfolio_resumeId_idx")
  @@index([workspaceImageId], map: "Portfolio_workspaceImageId_idx")
}

model project {
  id                String              @id
  title             String
  slug              String              @unique(map: "Project_slug_key")
  category          project_category
  featured          Boolean             @default(false)
  status            project_status
  shortDescription  String              @db.Text
  description       String              @db.LongText
  githubUrl         String?
  liveUrl           String?
  thumbnailId       String?
  features          Json?
  challenges        Json?
  learnings         Json?
  displayOrder      Int                 @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  media             media?              @relation(fields: [thumbnailId], references: [id], map: "Project_thumbnailId_fkey")
  projectimage      projectimage[]
  projecttechnology projecttechnology[]

  @@index([category], map: "Project_category_idx")
  @@index([featured], map: "Project_featured_idx")
  @@index([slug], map: "Project_slug_idx")
  @@index([status], map: "Project_status_idx")
  @@index([thumbnailId], map: "Project_thumbnailId_fkey")
}

model projectimage {
  id           String  @id
  projectId    String
  mediaId      String
  displayOrder Int     @default(0)
  media        media   @relation(fields: [mediaId], references: [id], onDelete: Cascade, map: "ProjectImage_mediaId_fkey")
  project      project @relation(fields: [projectId], references: [id], onDelete: Cascade, map: "ProjectImage_projectId_fkey")

  @@index([mediaId], map: "ProjectImage_mediaId_fkey")
  @@index([projectId], map: "ProjectImage_projectId_idx")
}

model projecttechnology {
  projectId    String
  technologyId String
  project      project    @relation(fields: [projectId], references: [id], onDelete: Cascade, map: "ProjectTechnology_projectId_fkey")
  technology   technology @relation(fields: [technologyId], references: [id], onDelete: Cascade, map: "ProjectTechnology_technologyId_fkey")

  @@id([projectId, technologyId])
  @@index([technologyId], map: "ProjectTechnology_technologyId_fkey")
}

model skill {
  id           String         @id
  name         String
  category     skill_category
  iconName     String?
  proficiency  Int?
  displayOrder Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
}

model technology {
  id                String              @id
  name              String              @unique(map: "Technology_name_key")
  iconName          String?
  projecttechnology projecttechnology[]
}

enum skill_category {
  FRONTEND
  BACKEND
  DATABASE
  DEVOPS
  LANGUAGE
  TOOL
}

enum internship_employmentType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  FREELANCE
}

enum project_category {
  FULL_STACK
  FRONTEND
  BACKEND
  ACADEMIC
  PERSONAL
}

enum media_type {
  IMAGE
  PDF
}

enum project_status {
  LIVE
  IN_DEVELOPMENT
  ARCHIVED
}
